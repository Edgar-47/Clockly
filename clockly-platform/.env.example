# PostgreSQL
DATABASE_URL=postgresql://clockly:clockly@localhost:5432/clockly
TEST_DATABASE_URL=postgresql://clockly:clockly@localhost:5432/clockly_test

# Runtime
CLOCKLY_ENV=development
CLOCKLY_SECRET_KEY=replace-with-a-long-random-secret
CLOCKLY_SESSION_MAX_AGE=28800
CLOCKLY_SECURE_COOKIES=false
CLOCKLY_DOCS_ENABLED=true
CLOCKLY_PUBLIC_BASE_URL=http://127.0.0.1:8000
CLOCKLY_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:8001,http://localhost:8001
CLOCKLY_TRUSTED_HOSTS=*
CLOCKLY_UPLOADS_DIR=uploads
CLOCKLY_MAX_UPLOAD_MB=5
# First route opened from /. Leave empty to restore role-based /login or /dashboard behavior.
DEFAULT_ROUTE=/kiosk

# Google OAuth owner/admin login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback

# Bootstrap admin de negocio inicial. No concede acceso Superadmin.
CLOCKLY_DEFAULT_ADMIN_USERNAME=admin
CLOCKLY_DEFAULT_ADMIN_PASSWORD=Admin123

# Superadmin se provisiona fuera de la app normal:
# python -m app.cli.superadmin create --email owner@example.com --name "Owner Name"

# Optional
CLOCKLY_KIOSK_MODE=false
CLOCKLY_DEBUG_FLOW=false
FICHAJE_EXPORTS_DIR=exports
