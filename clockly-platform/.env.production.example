# ClockLy production environment template
# Do not commit real secrets. Copy these keys to your host/provider settings.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

CLOCKLY_ENV=production
CLOCKLY_SECRET_KEY=replace-with-a-long-random-64-byte-secret
CLOCKLY_DEFAULT_ADMIN_USERNAME=admin
CLOCKLY_DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-initial-admin-password
CLOCKLY_SESSION_MAX_AGE=28800
CLOCKLY_SECURE_COOKIES=true
CLOCKLY_DOCS_ENABLED=false
CLOCKLY_PUBLIC_BASE_URL=https://your-production-domain.example
CLOCKLY_ALLOWED_ORIGINS=https://your-production-domain.example
CLOCKLY_TRUSTED_HOSTS=your-production-domain.example
CLOCKLY_UPLOADS_DIR=uploads
CLOCKLY_MAX_UPLOAD_MB=5
DEFAULT_ROUTE=/kiosk

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-production-domain.example/auth/google/callback

CLOCKLY_KIOSK_MODE=false
CLOCKLY_DEBUG_FLOW=false
FICHAJE_EXPORTS_DIR=exports
